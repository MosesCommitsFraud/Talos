# Talos environment configuration

# Web UI bind. Keep loopback unless Talos is behind a trusted HTTPS/private proxy.
APP_BIND=127.0.0.1
APP_PORT=7000
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
SECURE_COOKIES=false

# Optional first admin seed. Do not commit real passwords.
TALOS_ADMIN_USER=admin
# TALOS_ADMIN_PASSWORD=change_me_before_first_boot

# Existing Spark endpoints.
SPARK_HOST=192.168.10.91
LLM_HOST=192.168.10.91
LLM_HOSTS=192.168.10.91
OPENAI_API_KEY=not-needed
VLLM_BASE_URL=http://192.168.10.91:8000/v1
VLLM_API_KEY=not-needed
VLLM_MODEL=qwen3-llm

# Embeddings / reranking for Talos RAG.
EMBEDDING_URL=http://192.168.10.91:8001/v1/embeddings
EMBEDDING_MODEL=qwen3-embed
QDRANT_URL=http://192.168.10.91:6333
RERANK_URL=http://192.168.10.91:8002/v1/rerank
RERANK_MODEL=qwen3-reranker

# SQL MCP target. Use a new read-only login; the old one is considered compromised.
# SQLSERVER_HOST=192.168.10.16
# SQLSERVER_DATABASE=devQM_macs_QM_Test
# SQLSERVER_USER=talos_readonly
# SQLSERVER_PASSWORD=

# App persistence. SQLite is kept for the first Odysseus-based migration step.
DATABASE_URL=sqlite:///./data/app.db

# Internal sandbox API.
TALOS_SANDBOX_URL=http://talos-sandbox:7800
TALOS_OPENCODE_PORT_BASE=41000
TALOS_OPENCODE_IDLE_SECONDS=3600

# CORS allowed origins.
ALLOWED_ORIGINS=http://localhost:7000,http://127.0.0.1:7000

# Container user for app-owned bind mounts.
PUID=1000
PGID=1000
