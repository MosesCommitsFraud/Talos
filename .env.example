# Talos configuration — copy to `.env` and edit as needed.
#
#     cp .env.example .env
#
# EVERYTHING here is OPTIONAL. With no .env at all, `docker compose up` works
# out of the box: the app binds to 127.0.0.1 and the bundled datastores
# (Redis/Valkey, Qdrant) run on an internal Docker network with no published
# ports — the network is the trust boundary, so they need no passwords.
# Set values below only to override defaults or to harden an exposed deployment.

# ---- App / network ----
# APP_BIND controls which host interface the app port binds to. Default
# 127.0.0.1 = localhost only (not reachable from your LAN). Set 0.0.0.0 to
# expose it on the network — only do this behind auth / a reverse proxy.
APP_BIND=127.0.0.1
APP_PORT=7000

# ---- Auth ----
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
SECURE_COOKIES=false
# First-run admin. Leave the password blank to set it interactively on first
# login instead of baking a credential into the environment.
TALOS_ADMIN_USER=admin
TALOS_ADMIN_PASSWORD=
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ---- Sandbox ----
# Shared secret required on every app→sandbox call. The sandbox has no internet
# access and no published port; set a long random string only if you want auth
# on the daemon as well. Generate one with: openssl rand -hex 32
TALOS_SANDBOX_KEY=

# ---- RAG: Redis/Valkey (defense-in-depth, optional) ----
# Redis has NO published port and is only reachable by sibling containers, so it
# runs WITHOUT a password by default. To add a password anyway, set it here —
# it's enforced on the server and injected into REDIS_URL automatically.
# Generate one with: openssl rand -base64 24
RAG_REDIS_PASSWORD=

# ---- LLM / embeddings ----
# Point these at your own LLM/embedding host (no default is shipped).
# LLM_HOST=your-llm-host
# EMBEDDING_URL=http://your-llm-host:8001/v1/embeddings
# EMBEDDING_MODEL=your-embedding-model

# ---- Voice dictation (optional) ----
# Streaming speech-to-text for the composer mic. Enable with:
#   docker compose -f docker-compose.yml -f docker-compose.dictation.yml up -d --build
# The mic icon only shows while the sidecar is up and its models are loaded.
# All values below are optional overrides for the overlay's defaults.
# DICTATION_WS_URL=ws://dictation:8004/ws
# DICTATION_DEVICE=cpu
# DICTATION_MODEL=large-v3-turbo
# DICTATION_REALTIME_MODEL=small
# DICTATION_LANGUAGE=

# ---- Persistence / IDs ----
# DATABASE_URL=sqlite:///./data/app.db
# PUID=1000
# PGID=1000
